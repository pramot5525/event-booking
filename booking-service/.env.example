# Booking Service environment variables
# Copy this file to .env and adjust values as needed for your environment.

# HTTP service
SERVER_PORT=8082
EVENT_SERVICE_URL=http://localhost:8081

# PostgreSQL (event booking DB)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=eventbooking
POSTGRES_PASSWORD=eventbooking
POSTGRES_DB=eventdb

# Redis (caching/locking queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_DB=0
